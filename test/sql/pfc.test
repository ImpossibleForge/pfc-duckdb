# name: test/sql/pfc.test
# description: Tests for the pfc DuckDB extension (read_pfc_jsonl)
# group: [sql]

#
# These tests cover bind-time error handling only and do NOT require the pfc_jsonl binary.
# All errors below are raised before any subprocess is started (index read or argument parsing).

require pfc

# ─── Extension loads ───────────────────────────────────────────────────────────

statement ok
SELECT 1;

# ─── Error: wrong argument type ───────────────────────────────────────────────

statement error
SELECT * FROM read_pfc_jsonl(42);
----
No function matches

# ─── Error: empty path ────────────────────────────────────────────────────────

statement error
SELECT * FROM read_pfc_jsonl('');
----
path must not be empty

# ─── Error: file does not exist ───────────────────────────────────────────────

statement error
SELECT * FROM read_pfc_jsonl('/nonexistent/path/file.pfc');
----
Cannot open PFC file

# ─── Error: wrong type for ts_from ────────────────────────────────────────────
# DuckDB emits an internal cast error — just verify it errors, not the exact message

statement error
SELECT * FROM read_pfc_jsonl('/nonexistent.pfc', ts_from='not_a_number');
----
not_a_number

# ─── Error: wrong type for ts_to ──────────────────────────────────────────────

statement error
SELECT * FROM read_pfc_jsonl('/nonexistent.pfc', ts_to='not_a_number');
----
not_a_number

# ─── Error: unknown named parameter ───────────────────────────────────────────

statement error
SELECT * FROM read_pfc_jsonl('/nonexistent.pfc', unknown_param=1);
----
unknown_param
